{
  "name": "playkeep.io",
  "version": "0.1.0",
  "private": true,
  "description": "Open protocol prototype for sovereign digital game ownership.",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "demo:prepare": "tsx scripts/demo/prepare.ts",
    "demo:install": "tsx scripts/demo/install.ts",
    "demo:e2e": "pnpm test:e2e",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:e2e": "pnpm -r --if-present test:e2e",
    "test:integration": "pnpm -r --if-present test:integration",
    "test:unit": "pnpm -r --if-present test:unit",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
